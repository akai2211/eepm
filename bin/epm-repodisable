load_helper epm-sh-altlinux
load_helper epm-sh-repo


__epm_repodisable_alt()
{
    assure_root
    local rl
    # ^rpm means full string
    if rhas "$1" "\^rpm" ; then
        rl="$(echo "$1" | sed -e 's|\^||')"
    else
        rl="$(epm --quiet repo list "$@")"
        [ -z "$rl" ] && warning 'Can'\''t find $* entries in the repos (see epm repolist output)' && return 1
    fi
    local apt_lists
    apt_lists="$(filter_glob_list $APT_ALL_SOURCES_LIST)"
    [ -z "$apt_lists" ] && return 0
    echo "$rl" | while read rp ; do
        [ -n "$dryrun" ] && message 'will comment $rp' && continue
        sed -i -e "s|^\($(sed_escape "$rp")\)|#\1|" $apt_lists
    done
}


epm_repodisable()
{

case $PMTYPE in
    apt-rpm|apm-rpm)
        __epm_repodisable_alt "$@"
        ;;
    apt-dpkg|aptitude-dpkg)
        local files
        files="$(__find_deb822_files_by_pattern "$1")"
        if [ -n "$files" ] ; then
            assure_root
            echo "$files" | while read f ; do
                info "Disabling $f ..."
                __deb822_disable "$f"
            done
        else
            __epm_repodisable_alt "$@"
        fi
        ;;
    yum-rpm)
        docmd yum repolist $verbose
        [ -n "$verbose" ] || info "Use --verbose if you need detail information."
        ;;
    dnf-rpm)
        sudocmd dnf config-manager --enable $verbose "$@"
        ;;
    dnf5-rpm)
        sudocmd dnf config-manager setopt "$@.enabled=0"
        ;;
    pisi)
        docmd pisi disable-repo "$@"
        ;;
    eoget)
        docmd eoget disable-repo "$@"
        ;;
    *)
        fatal 'Have no suitable command for $PMTYPE in epm_repodisable()'
        ;;
esac

}
