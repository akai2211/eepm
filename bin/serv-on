load_helper serv-start
load_helper serv-enable
load_helper serv-status

serv_on()
{
    local SERVICE="$1"
    serv_enable "$SERVICE" || return
    # start if need
    is_service_running $SERVICE && info 'Service $SERVICE is already running' && return
    serv_start $SERVICE
}
