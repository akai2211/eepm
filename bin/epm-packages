load_helper epm-sh-warmup

__epm_packages_help()
{
    message "Print installed packages"
    message "Options:"
    get_help HELPOPTIONS $SHAREDIR/epm-packages
    message '
Examples:
  epm qa --short
  epm packages --sort
  epm packages --sort=size
  epm packages --last
'
}

__epm_packages_sort()
{

case $PMTYPE in
    *-rpm)
        # FIXME: space with quotes problems, use point instead
        warmup_rpmbase
        if [ -n "$short" ] ; then
            docmd rpm -qa --queryformat "%{size}@%{name}\n" "$@" | sed -e "s|@| |g" | sort -n -k1 -r
        else
            docmd rpm -qa --queryformat "%{size}@%{name}-%{version}-%{release}\n" "$@" | sed -e "s|@| |g" | sort -n -k1 -r
        fi
        ;;
    *-dpkg)
        warmup_dpkgbase
        if [ -n "$short" ] ; then
            docmd dpkg-query -W --showformat="\${Installed-Size}@\${Package}\n" "$@" | sed -e "s|@| |g" | sort -n -k1 -r
        else
            docmd dpkg-query -W --showformat="\${Installed-Size}@\${Package}-\${Version}:\${Architecture}\n" "$@" | sed -e "s|@| |g" | sort -n -k1 -r
        fi
        ;;
    *)
        fatal 'Sorted package list function is not implemented for $PMTYPE'
        ;;
esac
}

__epm_packages_last()
{
case $PMTYPE in
    *-rpm)
        # FIXME: space with quotes problems, use point instead
        warmup_rpmbase
        docmd rpm -qa --last
        ;;
    pacman)
        assure_exists expac
        docmd expac --timefmt='%Y-%m-%d %T' '%l\t%n %v' | sort | tail -200 | nl
        ;;
    *)
        fatal "Last package list function is not implemented for $PMTYPE"
        ;;
esac
}

__aptcyg_print_full()
{
    #showcmd apt-cyg show
    local VERSION=$(a= apt-cyg show "$1" | grep -m1 "^version: " | sed -e "s|^version: ||g")
    echo "$1-$VERSION"
}

__fo_pfn()
{
    grep -v "^$" | grep -- "$*"
}

# TODO: we have a problem with error status here
epm_packages()
{
    local CMD

    case "$1" in
        -h|--help|help)  # HELPOPTIONS: help
            __epm_packages_help
            return
            ;;
        --sort=size|--sort)   # HELPOPTIONS: list package(s) by size, most
            __epm_packages_sort
            return
            ;;
        --last|--sort=time)   # HELPOPTIONS: list package(s) by install time, most
            __epm_packages_last
            return
            ;;
        --short)              # HELPOPTIONS: print out short package names
            # for help entry only
            ;;
        "")
            ;;
        *)
            fatal 'Unknown option $1. Use epm packages --help to get help.'
    esac

case $PMTYPE in
    *-dpkg)
        warmup_dpkgbase
        if [ -n "$short" ] ; then
            docmd dpkg-query -W --showformat="\${db:Status-Abbrev}\${Package}\n" "$@" | grep "^.i" | sed -e "s|^.. ||g" | __fo_pfn "$@"
        else
            docmd dpkg-query -W --showformat="\${db:Status-Abbrev}\${Package}-\${Version}:\${Architecture} - \${Description}\n" "$@" | grep "^.i" | sed -e "s|^.. ||g" | cut -d'
' -f1 | __fo_pfn "$@"
        fi
        return ;;
    *-rpm)
        warmup_rpmbase
        if [ -n "$short" ] ; then
            docmd rpm -qa --queryformat "%{name}\n" "$@" | __fo_pfn "$@"
        else
            docmd rpm -qa --queryformat "%{name}-%{version}-%{release} - %{summary}\n" "$@" | __fo_pfn "$@"
        fi
        return ;;
    packagekit)
        docmd pkcon get-packages --filter installed
        ;;
    snappy)
        CMD="snappy info"
        ;;
    snap)
        if [ -n "$short" ] ; then
            docmd snap list 2>/dev/null | tail -n +2 | awk '{print $1}' | __fo_pfn "$@"
        else
            docmd snap list 2>/dev/null | tail -n +2 | awk '{print $1"-"$2" - "$4}' | __fo_pfn "$@"
        fi
        return
        ;;
    flatpak)
        if [ -n "$short" ] ; then
            docmd flatpak list --app --columns=application 2>/dev/null | __fo_pfn "$@"
        else
            docmd flatpak list --app --columns=application,version,name 2>/dev/null | awk -F'\t' '{print $1"-"$2" - "$3}' | __fo_pfn "$@"
        fi
        return
        ;;
    emerge)
        CMD="qlist -I -C"
        # print with colors for console output
        isatty && CMD="qlist -I"
        ;;
    pkgsrc)
        docmd pkg_info | sed -e "s| .*||g" | __fo_pfn "$@"
        return ;;
    pkgng)
        if [ -n "$short" ] ; then
            docmd pkg info 2>/dev/null | sed -e "s| .*||g" -e "s|-[0-9].*||g" | __fo_pfn "$@"
        else
            docmd pkg info 2>/dev/null | sed -e "s| | - |" | __fo_pfn "$@"
        fi
        return ;;
    pacman)
        if [ -n "$short" ] ; then
            docmd pacman -Q "$@" 2>/dev/null | sed -e "s| .*||g" | __fo_pfn "$@"
        else
            docmd pacman -Qi "$@" 2>/dev/null | awk '/^Name/{name=$3} /^Version/{ver=$3} /^Description/{$1=$2=""; desc=$0} /^$/{print name"-"ver" -"desc}' | __fo_pfn "$@"
        fi
        return
        ;;
    npackd)
        CMD="npackdcl list --status=installed"
        # TODO: use search if pkg_filenames is not empty
        ;;
    conary)
        CMD="conary query"
        ;;
    eopkg)
        if [ -n "$short" ] ; then
            docmd eopkg list-installed 2>/dev/null | sed -e "s| .*||g" | __fo_pfn "$@"
        else
            docmd eopkg list-installed 2>/dev/null | __fo_pfn "$@"
        fi
        return
        ;;
    stplr)
        CMD="stplr list --installed"
        ;;
    pisi)
        if [ -n "$short" ] ; then
            docmd pisi list-installed 2>/dev/null | sed -e "s| .*||g" | __fo_pfn "$@"
        else
            docmd pisi list-installed 2>/dev/null | __fo_pfn "$@"
        fi
        return
        ;;
    choco)
        CMD="choco list"
        ;;
    slackpkg)
        CMD="ls -1 /var/log/packages/"
        if [ -n "$short" ] ; then
            # FIXME: does not work for libjpeg-v8a
            # TODO: remove last 3 elements (if arch is second from the last?)
            # FIXME this hack
            docmd ls -1 /var/log/packages/ | sed -e "s|-[0-9].*||g" | sed -e "s|libjpeg-v8a.*|libjpeg|g" | __fo_pfn "$@"
            return
        fi
        ;;
    homebrew)
        docmd brew list | xargs -n1 echo
        ;;
    opkg)
        if [ -n "$short" ] ; then
            docmd opkg list-installed 2>/dev/null | awk '{print $1}' | __fo_pfn "$@"
        else
            docmd opkg list-installed 2>/dev/null | __fo_pfn "$@"
        fi
        return
        ;;
    apk)
        if [ -n "$short" ] ; then
            docmd apk list --installed 2>/dev/null | sed -e "s|-[0-9].*||g" | __fo_pfn "$@"
        else
            docmd apk list --installed 2>/dev/null | sed -e "s| \[installed\]||g" | __fo_pfn "$@"
        fi
        return
        ;;
    nix)
        if [ -n "$short" ] ; then
            docmd nix-env -q 2>/dev/null | sed -e "s|-[0-9].*||g" | __fo_pfn "$@"
        else
            docmd nix-env -q --description 2>/dev/null | sed -e "s|  *| - |" | __fo_pfn "$@"
        fi
        return
        ;;
    tce)
        CMD="ls -1 /usr/local/tce.installed"
        ;;
    guix)
        CMD="guix package -I"
        ;;
    appget)
        CMD="appget list"
        ;;
    winget)
        CMD="winget list"
        ;;
    termux-pkg)
        if [ -n "$short" ] ; then
            docmd pkg list-installed 2>/dev/null | sed -e "s|/.*||g" | __fo_pfn "$@"
        else
            docmd pkg list-installed 2>/dev/null | sed -e "s|/[^ ]* | - |" | __fo_pfn "$@"
        fi
        return
        ;;
    xbps)
        if [ -n "$short" ] ; then
            docmd xbps-query -l 2>/dev/null | sed -e "s|^ii ||g" -e "s| .*||g" -e "s|\(.*\)-.*|\1|g" | __fo_pfn "$@"
        else
            docmd xbps-query -l 2>/dev/null | sed -e "s|^ii ||g" -e "s| \+| - |" | __fo_pfn "$@"
        fi
        return 0
        ;;
    android)
        docmd pm list packages | sed -e "s|^package:||g" | __fo_pfn "$@"
        return
        ;;
    aptcyg)
        if [ -z "$short" ] ; then
            # TODO: fix this slow way
            for i in $(docmd apt-cyg list "$@") ; do
                __aptcyg_print_full $i
            done
            return
        fi
        CMD="apt-cyg list"
        ;;
    *)
        fatal 'Have no suitable query command for $PMTYPE'
        ;;
esac

docmd $CMD | __fo_pfn "$@"
# FIXME: we print empty lines, but will lost error status

}
